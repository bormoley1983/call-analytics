# Paths
PROJECT_ROOT=/work

# Source selection
#DAYS=2024/10/11,2024/10/14,2024/10/16,2024/10/17,2024/10/18
PROCESS_LIMIT=30

# Whisper
WHISPER_DEVICE=cuda
WHISPER_COMPUTE_TYPE=float16
WHISPER_MODEL=medium
MIN_BYTES=20000
MIN_SECONDS=1.0

# Ollama
OLLAMA_URL=http://host.docker.internal:11434
OLLAMA_MODEL=qwen3.5:latest

# Control
FORCE_REANALYZE=0
FORCE_TRANSLATE_UK=1
MAX_CHARS_ANALYZE=9000