# Paths
PROJECT_ROOT=/work

# Source selection
#DAYS=2024/10/11,2024/10/14,2024/10/16,2024/10/17,2024/10/18
PROCESS_LIMIT=30

# Whisper
WHISPER_DEVICE=cuda
WHISPER_COMPUTE_TYPE=float16
WHISPER_MODEL=large-v3-turbo
WHISPER_BEAM_SIZE=5
MIN_BYTES=20000
MIN_SECONDS=1.0

# Ollama
OLLAMA_URL=http://host.docker.internal:11434
OLLAMA_MODEL=qwen3.5:27b
OLLAMA_NUM_CTX=16384
OLLAMA_KEEP_ALIVE=1m
OLLAMA_THINK=0
# 1 = sequential (Ollama/single GPU). >1 = concurrent (vLLM, llama.cpp with parallel slots)
ANALYSIS_WORKERS=1

# Control
FORCE_REANALYZE=0
FORCE_TRANSLATE_UK=1
MAX_CHARS_ANALYZE=9000

#Log
LOG_LEVEL=DEBUG

#Postgres
#POSTGRES_DSN=postgresql://user:pass@host/db

# PBX sync
# PBX_HOST=192.168.10.202
# PBX_PORT=22
# PBX_USER=monitor_reader
# PBX_AUTH_MODE=key
# PBX_PASSWORD=
# PBX_KEY_PATH=/work/config/ssh/pbx_ed25519
# PBX_KNOWN_HOSTS_PATH=/work/config/ssh/known_hosts
# PBX_REMOTE_DIR=/var/spool/asterisk/monitor
